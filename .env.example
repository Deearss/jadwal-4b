# Toggle fitur notifikasi email (subscribe/unsubscribe/send-notifications)
# Set ke "true" untuk mengaktifkan, "false" atau hapus untuk menonaktifkan
NEXT_PUBLIC_SUBSCRIBE_ENABLED=true

# API key Brevo — dapatkan di app.brevo.com/settings/keys/api
# Wajib jika NEXT_PUBLIC_SUBSCRIBE_ENABLED=true
BREVO_API_KEY=your-brevo-api-key-here

# Email pengirim yang sudah diverifikasi di Brevo
# Wajib jika NEXT_PUBLIC_SUBSCRIBE_ENABLED=true
VERIFIED_SENDER_EMAIL=your-verified-sender@example.com

# Link Portal E-Learning UNISKA
NEXT_PUBLIC_ELEARNING_LINK=https://elearning.uniska-bjm.ac.id/

# Link Google Drive Kelas
NEXT_PUBLIC_GOOGLE_DRIVE_LINK=https://drive.google.com/drive/folders/your-folder-id
